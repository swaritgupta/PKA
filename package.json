    "pdfjs-dist": "^5.4.624",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tiktoken": "^1.0.22",
    "voyageai": "^0.2.0"
